@model linkedin.Models.Offre
@{
    ViewData["Title"] = "Modifier l'offre";
}

<div class="edit-offer-page">
    <!-- Header -->
    <div class="edit-header">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-8">
                    <h1 class="page-title">Modifier l'offre</h1>
                    <p class="page-subtitle">Mettez à jour les informations de cette offre d'emploi</p>
                </div>
                <div class="col-lg-4 text-end">
                    <a asp-action="Index" class="btn-back-to-list">
                        <i class="fas fa-arrow-left"></i>
                        Retour à la liste
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Contenu principal -->
    <div class="edit-content">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-8 col-xl-6">
                    <div class="edit-form-card">
                        <form asp-action="Edit" class="edit-form">
                            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                            <input type="hidden" asp-for="Id" />

                            <div class="form-group">
                                <label asp-for="Titre" class="form-label">
                                    <i class="fas fa-briefcase"></i>
                                    Titre du poste
                                </label>
                                <input asp-for="Titre" class="form-control" placeholder="Ex: Développeur Full Stack" />
                                <span asp-validation-for="Titre" class="text-danger"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="Description" class="form-label">
                                    <i class="fas fa-align-left"></i>
                                    Description du poste
                                </label>
                                <textarea asp-for="Description" class="form-control textarea-large" rows="5" placeholder="Décrivez les missions, responsabilités et environnement de travail..."></textarea>
                                <span asp-validation-for="Description" class="text-danger"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="DatePublication" class="form-label">
                                    <i class="fas fa-calendar-alt"></i>
                                    Date de publication
                                </label>
                                <input asp-for="DatePublication" class="form-control" type="date" />
                                <span asp-validation-for="DatePublication" class="text-danger"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="CompetencesRequises" class="form-label">
                                    <i class="fas fa-code"></i>
                                    Compétences requises
                                </label>
                                <input asp-for="CompetencesRequises" class="form-control" placeholder="Ex: C#, JavaScript, SQL (séparées par des virgules)" />
                                <small class="form-text">Séparez les compétences par des virgules</small>
                                <span asp-validation-for="CompetencesRequises" class="text-danger"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="ExperienceRequise" class="form-label">
                                    <i class="fas fa-user-tie"></i>
                                    Expérience requise
                                </label>
                                <input asp-for="ExperienceRequise" class="form-control" placeholder="Ex: 3 ans minimum" />
                                <span asp-validation-for="ExperienceRequise" class="text-danger"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="DiplomeRequis" class="form-label">
                                    <i class="fas fa-graduation-cap"></i>
                                    Diplôme requis
                                </label>
                                <input asp-for="DiplomeRequis" class="form-control" placeholder="Ex: Licence en informatique" />
                                <span asp-validation-for="DiplomeRequis" class="text-danger"></span>
                            </div>

                            <div class="form-actions">
                                <button type="submit" class="btn-save">
                                    <i class="fas fa-save"></i>
                                    Enregistrer les modifications
                                </button>
                                <a asp-action="Index" class="btn-cancel">
                                    Annuler
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>