*@
@{
}
@model IEnumerable<dynamic>
@{
    ViewData["Title"] = "Rapports des Offres et CV";
}

<div class="reports-modern-page">
    <!-- Header moderne -->
    <div class="simple-header">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-8">
                    <h2 class="reports-title">Rapports des Offres et CV</h2>
                </div>
                <div class="col-lg-4 text-end">
                    <a href="@Url.Action("Index", "Offres")" class="btn-back-to-list">
                        <i class="fas fa-arrow-left"></i>
                        Retour à la liste
                    </a>
                </div>
            </div>
        </div>
    </div>
    <!-- Contenu principal -->
    <div class="container">
        <div class="modern-table-wrapper">
            <!-- Tableau responsive directement -->
            <div class="table-responsive">
                @if (Model != null && Model.Any())
                {
                    <table class="table table-striped table-hover table-bordered shadow-sm modern-reports-table">
                        <thead class="table-dark">
                            <tr>
                                <th>ID Offre</th>
                                <th>Titre de l'Offre</th>
                                <th>Nombre de CV</th>
                                <th>Voir CV Pertinents</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td><span class="offer-id-cell">#@item.Id</span></td>
                                    <td><div class="offer-title-cell">@item.Titre</div></td>
                                    <td class="text-center"><span class="cv-count-badge">@item.CvCount</span></td>
                                    <td class="text-center">
                                        <a href="@Url.Action("ShowAccurateCvs", "Offres", new { offreId = item.Id })" class="btn btn-sm btn-primary">
                                            <i class="fas fa-search me-1"></i>
                                            Voir
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <!-- État vide -->
                    <div class="empty-state">
                        <i class="fas fa-inbox"></i>
                        <h3>Aucune offre disponible</h3>
                        <p>Il n'y a actuellement aucune offre d'emploi avec des CV soumis. Les données apparaîtront ici dès que des candidatures seront reçues.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>