@page
@model LoginModel
@{
    ViewData["Title"] = "Connexion";
}

<div class="login-container">
    <div class="login-card">
        <div class="login-header">
            <h1 class="login-title">Bienvenue sur cvMatch Pro</h1>
            <p class="login-subtitle">Connectez-vous pour accéder aux offres d'emploi</p>
        </div>

        <div class="login-content">
            <section>
                <form id="account" method="post" class="login-form">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="form-group">
                        <label asp-for="Input.Email" class="form-label">Email</label>
                        <div class="input-group">
                            <input asp-for="Input.Email" class="form-control" autocomplete="username"
                                   aria-required="true" placeholder="nom@exemple.com" />
                        </div>
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Input.Password" class="form-label">Mot de passe</label>
                        <div class="input-group">
                            <input asp-for="Input.Password" class="form-control" autocomplete="current-password"
                                   aria-required="true" placeholder="Votre mot de passe" />
                        </div>
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <div class="form-check">
                        <input class="form-check-input" asp-for="Input.RememberMe" />
                        <label asp-for="Input.RememberMe" class="form-check-label">
                            Se souvenir de moi
                        </label>
                    </div>

                    <button id="login-submit" type="submit" class="btn btn-primary btn-login">
                        <i class="fas fa-sign-in-alt me-2"></i>
                        Se connecter
                    </button>
                </form>

                <div class="login-links">
                    <a id="forgot-password" asp-page="./ForgotPassword" class="link">
                        <i class="fas fa-question-circle me-1"></i>
                        Mot de passe oublié ?
                    </a>
                    <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="link">
                        <i class="fas fa-user-plus me-1"></i>
                        Créer un compte
                    </a>
                </div>
            </section>

            @if ((Model.ExternalLogins?.Count ?? 0) > 0)
            {
                <div class="divider">
                    <span>ou</span>
                </div>

                <section class="external-login">
                    <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                        @foreach (var provider in Model.ExternalLogins!)
                        {
                            <button type="submit" class="btn btn-external" name="provider" value="@provider.Name"
                                    title="Se connecter avec @provider.DisplayName">
                                <i class="fab fa-@provider.Name.ToLower() me-2"></i>
                                Continuer avec @provider.DisplayName
                            </button>
                        }
                    </form>
                </section>
            }
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}